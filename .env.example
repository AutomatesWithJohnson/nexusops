# Alibaba Cloud / Qwen
DASHSCOPE_API_KEY=your_dashscope_api_key_here
ALIBABA_CLOUD_ACCESS_KEY=your_access_key
ALIBABA_CLOUD_SECRET_KEY=your_secret_key

# Database
POSTGRES_URL=postgresql+asyncpg://nexusops:password@localhost:5432/nexusops
REDIS_URL=redis://localhost:6379/0

# Email (Alibaba Direct Mail)
SMTP_HOST=smtpdm.aliyuncs.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password

# OSS
OSS_ENDPOINT=oss-us-east-1.aliyuncs.com
OSS_BUCKET=nexusops-documents
OSS_ACCESS_KEY=your_oss_key
OSS_SECRET_KEY=your_oss_secret

# Optional
OPENROUTER_API_KEY=your_openrouter_key
LOG_LEVEL=INFO
